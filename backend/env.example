{% extends "base.html" %}
{% block title %}Quiz Results — {{ quiz.title }}{% endblock %}
{% block content %}
<div class="dashboard-page">
  <div class="page-header">
    <a href="{{ url_for('dashboard') }}" class="back-link">← Dashboard</a>
    <h1>{{ quiz.title }} — Results</h1>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num">{{ attempts|length }}</div>
      <div class="stat-label">Attempted</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">{{ not_attempted|length }}</div>
      <div class="stat-label">Not Attempted</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">
        {% if attempts %}{{ (attempts|sum(attribute='score') / attempts|length)|round(1) }}{% else %}—{% endif %}
      </div>
      <div class="stat-label">Avg Score</div>
    </div>
  </div>

  <div class="results-layout">
    <div class="attempts-table-wrap">
      <h2>Student Scores 🏆</h2>
      {% if attempts %}
      <table class="results-table">
        <thead>
          <tr><th>Rank</th><th>Student</th><th>Score</th><th>Percentage</th><th>Grade</th></tr>
        </thead>
        <tbody>
          {% for a in attempts %}
          {% set pct = (a.score / a.total * 100)|int %}
          <tr>
            <td>
              {% if loop.index == 1 %}🥇{% elif loop.index == 2 %}🥈{% elif loop.index == 3 %}🥉{% else %}{{ loop.index }}{% endif %}
            </td>
            <td>{{ a.student_username }}</td>
            <td>{{ a.score }} / {{ a.total }}</td>
            <td>
              <div class="table-progress">
                <div class="table-progress-fill" style="width:{{ pct }}%"></div>
                <span>{{ pct }}%</span>
              </div>
            </td>
            <td>
              <span class="grade-chip {% if pct >= 80 %}grade-a{% elif pct >= 60 %}grade-b{% elif pct >= 40 %}grade-c{% else %}grade-d{% endif %}">
                {% if pct >= 80 %}A{% elif pct >= 60 %}B{% elif pct >= 40 %}C{% else %}D{% endif %}
              </span>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="empty-state small">No students have attempted this quiz yet.</div>
      {% endif %}
    </div>

    <div class="not-attempted-panel">
      <h2>Pending Students</h2>
      {% if not_attempted %}
      <ul class="pending-list">
        {% for s in not_attempted %}
        <li>👤 {{ s }}</li>
        {% endfor %}
      </ul>
      {% else %}
      <p class="all-done">✅ All students have attempted!</p>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
